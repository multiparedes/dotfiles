[init]
	defaultBranch = master
[cola]
	startupmode = list
[alias]
	safe-commit = "!f() { grep -r --exclude-dir=.git -nE \"TODO|FIXME\" . && echo \"❌ No puedes commitear con TODOs\" && return 1 || git commit \"$@\"; }; f"
	lg = log --graph --date-order --abbrev-commit --decorate --format=format:'%C(bold blue)%h%C(reset) - %C(bold green)(%ar)%C(reset) %C(white)%s%C(reset) %C(dim white)- %an%C(reset)%C(bold yellow)%d%C(reset)' --all
[fetch]
	prune = true
[core]
	editor = nvim
[pull]
	rebase = true

[include]
	path = ~/.gitconfig-local
[includeIf "gitdir:~/multiparedes/"]
	path = ~/.gitconfig-personal
